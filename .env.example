# LLM — Groq via LiteLLM (no Ollama)
LLM_PROVIDER=groq
GROQ_API_KEY=your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Google AI Studio — fallback when Groq hits rate limits
GEMINI_API_KEY=
LITELLM_MODEL=cortex-groq
LITELLM_FALLBACK_MODEL=cortex-gemini
LITELLM_URL=http://localhost:4000
LITELLM_MASTER_KEY=cortex-local-dev

# Database
DATABASE_URL=postgresql://cortex:cortex@localhost:5434/cortex

# Better Auth (sign-in)
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Token encryption for connected_accounts (openssl rand -base64 32)
ENCRYPTION_KEY=

# GitHub OAuth — sign-in (Better Auth)
# Callback: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub OAuth — onboarding connectors (separate OAuth App recommended)
# Callback: http://localhost:3000/api/oauth/callback/github
GITHUB_CONNECT_CLIENT_ID=
GITHUB_CONNECT_CLIENT_SECRET=
GITHUB_CONNECT_REDIRECT_URI=http://localhost:3000/api/oauth/callback/github

# Google OAuth (sign-in + connector ingest)
# Sign-in callback:     http://localhost:3000/api/auth/callback/google
# Connector callback:   http://localhost:3000/api/oauth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CONNECT_REDIRECT_URI=http://localhost:3000/api/oauth/callback/google

# Integration service (direct OAuth — no Nango)
INTEGRATION_SERVICE_PORT=3010
NEXT_PUBLIC_INTEGRATION_SERVICE_URL=http://localhost:3010
INTEGRATION_SERVICE_PUBLIC_URL=http://localhost:3010

# Kafka
KAFKA_BROKERS=localhost:9092

# Redis
REDIS_URL=redis://localhost:6380

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cortexneo4j
NEO4J_HTTP_URL=http://localhost:7474

# Temporal
TEMPORAL_ADDRESS=localhost:7233

# Notion (server-side integration token)
NOTION_ACCESS_TOKEN=

# Entity extraction
USE_LLM_ENTITY_EXTRACTION=true

# Observability
LOKI_URL=http://localhost:3100
LOG_LEVEL=info
